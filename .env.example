# ── LLM API Keys (pick one — multi-provider YAML or single .env) ──────
# For single-model .env mode:
# OPENAI_API_BASE_URL=https://...
# OPENAI_API_KEY=*********
# OPENAI_MODEL=gpt-xxx

# For multi-provider config/llm.yaml mode:
BIGMODEL_API_KEY=*********
OPENAI_API_KEY=*********
DASHSCOPE_API_KEY=*********
MINIMAX_API_KEY=*********

# ── LangSmith tracing (optional) ──────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=******
# LANGCHAIN_PROJECT=my-info-vw

# ── Config directory (optional, defaults to ./config) ─────────────────
# MY_INFO_VW_CONFIG_DIR=/etc/my-info-vw
